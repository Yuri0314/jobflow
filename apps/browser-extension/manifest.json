{
  "manifest_version": 3,
  "name": "Jobflow Capture",
  "version": "0.1.0",
  "key": "",
  "description": "Capture job pages as Jobflow protocol envelopes.",
  "permissions": ["activeTab", "clipboardWrite"],
  "action": {
    "default_title": "Jobflow Capture",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.global.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.global.js"],
      "run_at": "document_idle"
    }
  ]
}
